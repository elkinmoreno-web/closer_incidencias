# Copia este archivo a .env.local y rellena con los valores de tu proyecto Supabase
# (Project Settings > API en el panel de Supabase)

NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key-publica

# SOLO para operaciones de servidor con privilegios elevados (crear usuarios admin).
# NUNCA la expongas en el cliente ni la subas a git.
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key-secreta

# URL pública donde vive la app (para construir los enlaces mágicos de los riders).
# En local: http://localhost:3000  |  En Vercel: https://tu-dominio.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000
